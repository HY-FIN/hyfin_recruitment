generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Applicant {
  id             String   @id @default(cuid())

  // 인적사항
  name           String
  phone          String
  birthDate      String
  email          String
  address        String

  // 학적사항
  university     String
  grade          String
  major          String
  gpa            String
  subMajor       String?
  graduationPlan String?

  // 경력사항 (JSON 배열로 저장)
  careers        String   @default("[]")

  // 자기소개서
  essay1         String
  essay2         String
  essay3         String
  essay4         String

  // 상태 및 타임스탬프
  status         String   @default("PENDING")
  appliedAt      DateTime @default(now())

  // 이메일 발송 여부
  receiptEmailSent   Boolean @default(false)
  docEmailSent       Boolean @default(false)
  interviewEmailSent Boolean @default(false)
  finalEmailSent     Boolean @default(false)

  // 면접 희망 시간 슬롯 ID 배열 (JSON)
  interviewPreferences String @default("[]")

  // 배정된 면접 슬롯
  interviewSlotId String?

  evaluations    Evaluation[]
  notifications  NotificationLog[]
  interviewSlot  InterviewSlot? @relation(fields: [interviewSlotId], references: [id])
}

model Evaluation {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  staffName   String

  // 서류 평가
  docScore    Int?
  docComment  String?
  personalQuestion String?

  // 면접 평가
  interviewScore   Int?
  interviewComment String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([applicantId, staffName])
}

model InterviewSlot {
  id         String      @id @default(cuid())
  date       String      // "2026-08-18"
  startTime  String      // "18:00"
  endTime    String      // "18:30"
  maxCount   Int         @default(3)
  applicants Applicant[]
}

model CommonQuestion {
  id        String   @id @default(cuid())
  day       Int      @unique // 1, 2, 3
  questions String   @default("[]")
  updatedAt DateTime @updatedAt
}

model FinalQuestion {
  id          String   @id @default(cuid())
  applicantId String   @unique
  question    String
  updatedAt   DateTime @updatedAt
}

model NotificationLog {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  type        String
  channel     String
  success     Boolean
  sentAt      DateTime  @default(now())
}
