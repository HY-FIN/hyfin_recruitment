generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ApplicationStage {
  SUBMITTED       // 접수 완료 (접수 메일 자동 발송)
  DOC_REVIEWING   // 서류 평가 중
  DOC_COMPLETED   // 서류 결과 확정 (합불 메일 발송 전)
  DOC_REJECTED    // 서류 불합격 메일 발송 완료
  INTERVIEW_READY // 서류합격 메일 발송 완료, 면접 시간 안내 전
  INTERVIEW_SET   // 면접 시간 안내 완료
  FINISHED        // 최종합불 메일 발송 완료
}

enum DocResult {
  PASS
  FAIL
}

enum FinalResult {
  PASS
  FAIL
}

model Applicant {
  id             String   @id @default(cuid())

  // 인적사항
  name           String
  phone          String
  birthDate      String
  email          String
  address        String?
  gender         String

  // 학적사항
  studentId      String
  grade          String
  major          String
  gpa            String
  subMajor       String?
  graduationPlan String?

  // 경력사항 (JSON 배열로 저장)
  careers        String   @default("[]")

  // 자기소개서
  essay1         String
  essay2         String
  essay3         String
  essay4         String

  // 상태 및 타임스탬프
  stage          ApplicationStage @default(SUBMITTED)
  docResult      DocResult?
  finalResult    FinalResult?
  appliedAt      DateTime @default(now())

  // 면접 희망 시간 슬롯 ID 배열 (JSON)
  interviewPreferences String @default("[]")

  // 배정된 면접 슬롯
  interviewSlotId String?

  evaluations    Evaluation[]
  notifications  NotificationLog[]
  interviewSlot  InterviewSlot? @relation(fields: [interviewSlotId], references: [id])
}

model Evaluation {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  staffName   String

  // 서류 평가
  docScore    Int?
  docComment  String?
  personalQuestion String?

  // 면접 평가
  interviewScore   Int?
  interviewComment String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([applicantId, staffName])
}

model InterviewSlot {
  id         String      @id @default(cuid())
  date       String      // "2026-08-18"
  startTime  String      // "18:00"
  endTime    String      // "18:30"
  maxCount   Int         @default(3)
  applicants Applicant[]
}

model CommonQuestion {
  id        String   @id @default(cuid())
  day       Int      @unique // 1, 2, 3
  questions String   @default("[]")
  location  String?
  updatedAt DateTime @updatedAt
}

model FinalQuestion {
  id          String   @id @default(cuid())
  applicantId String   @unique
  question    String
  updatedAt   DateTime @updatedAt
}

model NotificationLog {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  type        String
  channel     String
  success     Boolean
  sentAt      DateTime  @default(now())
}
